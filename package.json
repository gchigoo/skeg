{
  "name": "@gchigoo/skeg",
  "version": "1.0.2",
  "description": "Minimal engineering workflow for coding agents. Stay light. Hold course.",
  "type": "module",
  "keywords": [
    "pi-package",
    "coding-agent",
    "workflow"
  ],
  "license": "MIT",
  "exports": {
    "./provider-api": "./src/provider-api.ts",
    "./*": "./*"
  },
  "bin": {
    "skeg-provider-test": "./scripts/provider-test.mjs"
  },
  "files": [
    "extensions",
    "prompts",
    "src",
    "scripts/provider-test.mjs",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "NON_GOALS.md"
  ],
  "engines": {
    "node": ">=22 <25"
  },
  "pi": {
    "extensions": [
      "./extensions/core.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "dogfood": "node --experimental-strip-types dogfood/run.ts",
    "smoke": "node dogfood/pi-smoke.mjs",
    "dogfood:host": "node dogfood/host-dogfood.mjs",
    "dogfood:adversarial": "node --experimental-strip-types dogfood/adversarial.mjs",
    "dogfood:runtime": "node --experimental-strip-types dogfood/runtime-invariants.mjs",
    "check:budgets": "node scripts/check-budgets.mjs",
    "check:loc": "node scripts/check-budgets.mjs --loc",
    "check:providers": "node scripts/check-providers.mjs",
    "typecheck": "tsc --noEmit",
    "dogfood:dist": "node dogfood/dist-e2e.mjs",
    "verify": "npm test && npm run typecheck && npm run check:budgets && npm run check:providers && npm run dogfood:adversarial && npm run dogfood:runtime && npm run dogfood",
    "verify:dist": "npm run verify && npm pack --dry-run && npm run dogfood:dist"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0 <0.90.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
