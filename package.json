{
  "name": "@gchigoo/skeg",
  "version": "0.5.0",
  "description": "Minimal engineering workflow for coding agents. Stay light. Hold course.",
  "type": "module",
  "keywords": [
    "pi-package",
    "coding-agent",
    "workflow"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "prompts",
    "src",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/core.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "dogfood": "node --experimental-strip-types dogfood/run.ts",
    "smoke": "node dogfood/pi-smoke.mjs",
    "dogfood:host": "node dogfood/host-dogfood.mjs",
    "dogfood:adversarial": "node --experimental-strip-types dogfood/adversarial.mjs",
    "check:budgets": "node scripts/check-budgets.mjs",
    "check:loc": "node scripts/check-budgets.mjs --loc",
    "typecheck": "tsc --noEmit",
    "verify": "npm test && npm run typecheck && npm run check:budgets && npm run dogfood:adversarial && npm run dogfood"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0 <0.90.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
